# JARVIS 本地 Secrets 配置示例
# 复制此文件为 secrets.toml 并填入你的 API Key
# secrets.toml 已被 .gitignore 排除，不会推送到 GitHub

# LLM 配置 — DeepSeek V4
LLM_API_KEY = "your-api-key-here"
LLM_BASE_URL = "https://api.deepseek.com/v1"
LLM_MODEL = "deepseek-chat"
LLM_TIMEOUT = "15.0"

# 威胁情报 API Key（可选）
THREAT_INTEL_API_KEY = ""
